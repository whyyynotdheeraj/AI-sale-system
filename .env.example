# AI Sales OS Configuration
# Copy this file to .env and fill in the values for local development.
# On Render, set these in the "Environment" tab of your web service.

# ── Database ──────────────────────────────────────────────────
# Leave blank to use SQLite locally (default).
# For production on Render, set this to a Neon/Supabase PostgreSQL URL.
# DATABASE_URL=postgresql://username:password@hostname/dbname

# ── Security ──────────────────────────────────────────────────
# A random secret key for session signing. Generate one with:
# python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=your_secret_key_here

# ── Future Channel Integration API Keys ───────────────────────
# EMAIL_API_KEY=your_email_api_key
# WHATSAPP_API_KEY=your_whatsapp_api_key
# INSTAGRAM_API_KEY=your_instagram_api_key
# FACEBOOK_API_KEY=your_facebook_api_key
